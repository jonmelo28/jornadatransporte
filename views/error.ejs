<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="col-md-8 col-lg-6 text-center">
    <div class="p-5 border border-1 border-slate-200 rounded-4 bg-white shadow-sm">
      <div class="mb-4">
        <i class="fa-solid fa-circle-exclamation text-danger fs-1" style="font-size: 5rem !important;"></i>
      </div>
      
      <h2 class="display-font text-dark mb-2"><%= title %></h2>
      
      <% if (error && error.status) { %>
        <h5 class="text-muted mb-3">Status: <%= error.status %></h5>
      <% } %>

      <p class="text-secondary mb-4 fs-6"><%= message %></p>
      
      <% if (error && error.stack && process.env.NODE_ENV === 'development') { %>
        <div class="text-start bg-light p-3 rounded mb-4 font-monospace overflow-auto" style="max-height: 200px; font-size: 0.75rem;">
          <%= error.stack %>
        </div>
      <% } %>

      <div class="d-flex justify-content-center gap-3">
        <a href="/" class="btn-grad py-2 px-4">
          <i class="fa-solid fa-house"></i> Ir para o Início
        </a>
        <button onclick="window.history.back()" class="btn btn-outline-secondary py-2 px-4 fw-semibold rounded-3">
          <i class="fa-solid fa-arrow-left"></i> Voltar à Página Anterior
        </button>
      </div>
    </div>
  </div>
</div>

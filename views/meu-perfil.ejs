<div class="page-header">
  <div class="page-title-section">
    <h1 class="display-font">Meu Perfil</h1>
    <span class="page-subtitle">Gerencie suas informações pessoais e altere sua senha de acesso.</span>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-lg-6">
    
    <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show d-flex align-items-center py-2 px-3 border-0 rounded-3 mb-4" style="background-color: var(--success-bg); color: var(--success);" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>
        <div style="font-size: 0.875rem;"><%= success %></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; padding: 0.75rem 1rem;"></button>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center py-2 px-3 border-0 rounded-3 mb-4" style="background-color: var(--danger-bg); color: var(--danger);" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>
        <div style="font-size: 0.875rem;"><%= error %></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 0.75rem; padding: 0.75rem 1rem;"></button>
      </div>
    <% } %>

    <div class="card-premium">
      <div class="card-premium-header">
        <h5 class="m-0 display-font">Minhas Informações</h5>
      </div>
      <div class="card-premium-body">
        <form action="/meu-perfil" method="POST">
          <div class="form-group-premium">
            <label for="nome" class="form-label-premium">Nome de Exibição</label>
            <input type="text" name="nome" id="nome" class="form-control-premium" value="<%= profile.nome %>" required>
          </div>

          <div class="form-group-premium">
            <label for="email" class="form-label-premium">E-mail (Login)</label>
            <input type="email" name="email" id="email" class="form-control-premium" value="<%= profile.email %>" required>
          </div>

          <div class="form-group-premium">
            <label for="senha" class="form-label-premium">Nova Senha</label>
            <input type="password" name="senha" id="senha" class="form-control-premium" placeholder="Preencha apenas se quiser alterar a senha atual">
          </div>

          <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
            <button type="submit" class="btn-grad py-2 px-4">
              <i class="fa-solid fa-user-pen"></i> Atualizar Perfil
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
